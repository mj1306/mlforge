# Copy this file to .env and adjust as needed. `docker compose up` reads
# .env automatically for the ${VAR:-default} substitutions in docker-compose.yml.

# --- Ports published on your host ---
BACKEND_PORT=8000
FRONTEND_PORT=5173

# --- CORS: origins allowed to call the backend (comma-separated) ---
CORS_ALLOW_ORIGINS=http://localhost:5173

# --- Frontend build-time API base URL (baked into the JS bundle) ---
VITE_API_BASE_URL=http://localhost:8000

# --- Training/processing concurrency ---
# Keep TRAINING_MAX_WORKERS=1 unless you have multiple GPUs -- YOLO training
# saturates a single GPU, so a second concurrent job would just contend for it.
TRAINING_MAX_WORKERS=1
PROCESSING_MAX_WORKERS=2

# --- GPU training ---
# Leave empty for CPU-only wheels (works everywhere, no GPU/driver needed).
# For CUDA training, set this to match your driver, e.g.:
#   TORCH_INDEX_URL=https://download.pytorch.org/whl/cu121
# and make sure the NVIDIA Container Toolkit is installed on the host so the
# `deploy.resources.reservations.devices` GPU passthrough in docker-compose.yml
# actually has a GPU to reserve (remove that block entirely for CPU-only runs).
TORCH_INDEX_URL=

# --- CVAT (annotation tool), launched on demand via the "Launch CVAT" button ---
CVAT_URL=http://host.docker.internal:8080
CVAT_STARTUP_TIMEOUT_S=120

# --- Accounts & sessions ---
# Session lifetime for the login cookie. Set SESSION_COOKIE_SECURE=true only
# if you serve the backend over HTTPS (the cookie is then HTTPS-only).
SESSION_TTL_DAYS=30
SESSION_COOKIE_SECURE=false
